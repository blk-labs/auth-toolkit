{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
     "composite": true,
    "paths": {
      "@/*": ["./src/*"],
       "@core/*": ["./src/*"],
       "@auth/types": ["./src/types/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "./src/types/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}